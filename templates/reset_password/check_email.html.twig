{% extends 'base.html.twig' %}

{% block title %}
    Password Reset Email Sent
{% endblock %}

{% block body %}

    <div class="container min-vh-100 d-flex align-items-center justify-content-center">

        <div class="col-md-8 col-lg-6">

            <div class="card border-0 shadow-lg rounded-4">

                <div class="card-body p-5 text-center">

                    <div
                        class="bg-success text-white rounded-circle d-inline-flex align-items-center justify-content-center mb-4"
                        style="width:80px;height:80px;"
                    >

                        <i class="bi bi-envelope-check fs-2"></i>

                    </div>

                    <h2 class="fw-bold mb-3">

                        Check Your Email

                    </h2>

                    <p class="text-muted mb-4">

                        If an account matching your email exists,
                        we have sent a password reset link.

                    </p>

                    <div
                        class="alert alert-light border rounded-3 mb-4"
                    >

                        <strong>

                            Link expiration:

                        </strong>

                        <br>

                        {{ resetToken.expirationMessageKey|trans(
                            resetToken.expirationMessageData,
                            'ResetPasswordBundle'
                        ) }}

                    </div>

                    <div
                        class="bg-light rounded-3 p-3 mb-4"
                    >

                        <small class="text-muted">

                            Didn't receive the email?

                            Check your spam folder or request a new
                            reset link.

                        </small>

                    </div>

                    <a
                        href="{{ path(
                            'app_forgot_password_request'
                        ) }}"
                        class="btn btn-primary btn-lg rounded-3 px-4"
                    >

                        Try Again

                    </a>

                </div>

            </div>

        </div>

    </div>

{% endblock %}

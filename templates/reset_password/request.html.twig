{% extends 'base.html.twig' %}

{% block title %}Reset your password{% endblock %}

{% block body %}
    <div class="container min-vh-100 d-flex align-items-center justify-content-center">

        <div class="col-md-7 col-lg-5">

            <div class="card border-0 shadow-lg rounded-4">

                <div class="card-body p-5">

                    <div class="text-center mb-4">

                        <div
                            class="bg-warning text-white rounded-circle d-inline-flex align-items-center justify-content-center mb-3"
                            style="width:70px;height:70px;"
                        >

                            <i class="bi bi-key fs-3"></i>

                        </div>

                        <h2 class="fw-bold mb-1">

                            Reset Password

                        </h2>

                        <p class="text-muted">

                            Enter your email to receive a reset link

                        </p>

                    </div>

                    {% for flash_error in app.flashes(
                        'reset_password_error'
                    ) %}

                        <div
                            class="alert alert-danger rounded-3"
                            role="alert"
                        >

                            {{ flash_error }}

                        </div>

                    {% endfor %}

                    {{ form_start(requestForm) }}

                    <div class="mb-3">

                        {{ form_row(
                            requestForm.email,
                            {
                                attr: {
                                class: 'form-control form-control-lg',
                                placeholder: 'Enter your email'
                            }
                            }
                        ) }}

                    </div>

                    <div
                        class="bg-light rounded-3 p-3 mb-4"
                    >

                        <small class="text-muted">

                            We will send a secure link to your email
                            address so you can reset your password.

                        </small>

                    </div>

                    <button
                        class="btn btn-warning btn-lg w-100 rounded-3 mb-3"
                    >

                        <i class="bi bi-envelope me-2"></i>

                        Send Reset Email

                    </button>

                    <div class="text-center">

                        <a
                            href="{{ path('app_login') }}"
                            class="text-decoration-none"
                        >

                            ← Back to login

                        </a>

                    </div>

                    {{ form_end(requestForm) }}

                </div>

            </div>

        </div>

    </div>
{% endblock %}

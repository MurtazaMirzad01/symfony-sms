<table class="table table-striped table-hover">
    <thead class="table-dark">
    <tr>
        <th>Id</th>
        <th>Name</th>
        <th>Email</th>
        <th>Phone</th>
        <th>CreatedAt</th>
        <th>Image</th>
        <th>actions</th>
    </tr>
    </thead>
    <tbody>
    {% for student in students %}
        <tr>
            <td>{{ student.id }}</td>
            <td>{{ student.name }}</td>
            <td>{{ student.email }}</td>
            <td>{{ student.phone }}</td>
            <td>{{ student.createdAt ? student.createdAt|date('Y-m-d H:i:s') : '' }}</td>
            <td> {% if student.imageName %}

                    <img
                        src="{{ asset(
                            'uploads/students/' ~
                            student.imageName
                        ) }}"
                        width="60"
                        class="rounded"
                     alt="student image"/>

                {% endif %}</td>
            <td>
                <a
                    class="btn btn-sm btn-info"
                    href="{{ path('app_student_show', {'_locale': app.request.locale,'id': student.id}) }}"
                >{{ 'show'|trans }}</a>

                {% if is_granted(
                    'STUDENT_EDIT',
                    student
                    )
                %}
                <a
                    class="btn btn-sm btn-warning"
                    href="{{ path('app_student_edit', {'id': student.id, '_locale': app.request.locale
                    }) }}"
                >{{ 'edit'|trans }}</a>
                {% endif %}
                {% if is_granted(
                    'STUDENT_DELETE',
                    student,
                ) %}
                {{ include(
                    'student/_delete_form.html.twig'
                ) }}
                {% endif %}
            </td>
        </tr>
    {% else %}
        <tr>
            <td colspan="6">no records found</td>
        </tr>
    {% endfor %}
    </tbody>
</table>

<div class="d-flex justify-content-center mt-4">

    <nav class="shadow-sm p-2 rounded bg-white">

        {{ knp_pagination_render(students) }}

    </nav>

</div>

{% extends 'base.html.twig' %}

{% block title %}Student{% endblock %}

{% block body %}
    <div class="d-flex justify-content-between align-items-center mb-3">

    <h1>Student</h1>

        <a href="{{ path('app_student_new') }}"
           class="btn btn-primary">Add Student</a>
    </div>

    <div class="card mb-3">

        <div class="card-body">

            {{ form_start(searchForm) }}

            <div class="row">

                <div class="col-md-10">

                    {{ form_widget(
                        searchForm.query
                    ) }}

                </div>

                <div class="col-md-2">

                    <button
                        class="
                    btn
                    btn-primary
                    w-100">

                        Search

                    </button>

                </div>

            </div>

            {{ form_end(searchForm) }}

        </div>

    </div>

    {{ include('student/_table.html.twig',
        {
            students: students
        }
    ) }}

{% endblock %}

{% extends 'base.html.twig' %}

{% block title %}Student{% endblock %}

{% block body %}
    <div class="d-flex justify-content-between align-items-center mb-3">

    <h1>Student</h1>

        <a href="{{ path('app_student_new') }}"
           class="btn btn-primary">Add Student</a>
    </div>

    <div class="card mb-3">

        <div class="card-body">

            {{ form_start(searchForm) }}

            <div class="row">

                <div class="col-md-10">

                    {{ form_widget(
                        searchForm.query
                    ) }}

                </div>

                <div class="col-md-2">

                    <button
                        class="
                    btn
                    btn-primary
                    w-100">

                        Search

                    </button>

                </div>

            </div>

            {{ form_end(searchForm) }}

        </div>

    </div>

    <table class="table table-striped table-hover">
        <thead class="table-dark">
            <tr>
                <th>Id</th>
                <th>Name</th>
                <th>Email</th>
                <th>Phone</th>
                <th>CreatedAt</th>
                <th>actions</th>
            </tr>
        </thead>
        <tbody>
        {% for student in students %}
            <tr>
                <td>{{ student.id }}</td>
                <td>{{ student.name }}</td>
                <td>{{ student.email }}</td>
                <td>{{ student.phone }}</td>
                <td>{{ student.createdAt ? student.createdAt|date('Y-m-d H:i:s') : '' }}</td>
                <td>
                    <a
                        class="btn btn-sm btn-info"
                        href="{{ path('app_student_show', {'id': student.id}) }}"
                    >show</a>
                    <a
                        class="btn btn-sm btn-warning"
                        href="{{ path('app_student_edit', {'id': student.id}) }}"
                    >edit</a>
                    {{ include(
                        'student/_delete_form.html.twig'
                    ) }}
                </td>
            </tr>
        {% else %}
            <tr>
                <td colspan="6">no records found</td>
            </tr>
        {% endfor %}
        </tbody>
    </table>
{% endblock %}

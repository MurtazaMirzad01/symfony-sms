{% extends 'base.html.twig' %}

{% block title %}Student Detail{% endblock %}

{% block body %}
    <h1>{{ 'student.student detail'|trans }}</h1>

    <table class="table">
        <tbody>
            <tr>
                <th>Id</th>
                <td>{{ student.id }}</td>
            </tr>
            <tr>
                <th>Name</th>
                <td>{{ student.name }}</td>
            </tr>
            <tr>
                <th>Email</th>
                <td>{{ student.email }}</td>
            </tr>
            <tr>
                <th>Phone</th>
                <td>{{ student.phone }}</td>
            </tr>
            <tr>
                <th>CreatedAt</th>
                <td>{{ student.createdAt ? student.createdAt|date('Y-m-d H:i:s') : '' }}</td>
            </tr>
        </tbody>
    </table>

    <a href="{{ path('app_student_index') }}" class="btn btn-info">{{ 'back to list'|trans }}</a>
    {% if is_granted(
        'STUDENT_EDIT',
        student
    ) %}
    <a href="{{ path('app_student_edit', {'id': student.id}) }}" class="btn btn-warning">edit</a>
    {% endif %}

    {% if is_granted(
        'STUDENT_DELETE',
        student
    ) %}
    {{ include('student/_delete_form.html.twig') }}
    {% endif %}
{% endblock %}
